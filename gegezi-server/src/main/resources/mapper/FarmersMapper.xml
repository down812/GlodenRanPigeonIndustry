<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sky.mapper.FarmersMapper">




    <insert id="insertFarmer" parameterType="com.sky.entity.Farmers">
        INSERT INTO farmers (name, region, numbers)
        VALUES (#{name}, #{region}, #{numbers})
    </insert>


    <delete id="deleteFarmerByName" parameterType="String">
        DELETE FROM farmers
        WHERE name = #{name}
    </delete>


    <select id="selectAllFarmers" resultType="com.sky.entity.Farmers">
        SELECT id, name, region, numbers
        FROM farmers
    </select>
</mapper>